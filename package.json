{
    "name": "pokie",
    "version": "1.3.0",
    "description": "A server-side video slot game logic framework for JavaScript and TypeScript.",
    "type": "module",
    "exports": {
        "import": {
            "types": "./dist/esm/index.d.ts",
            "default": "./dist/esm/index.js"
        },
        "require": {
            "types": "./dist/cjs/index.d.ts",
            "default": "./dist/cjs/index.js"
        }
    },
    "main": "./dist/cjs/index.js",
    "types": "./dist/cjs/index.d.ts",
    "bin": {
        "pokie": "./dist/cli/pokie.js"
    },
    "scripts": {
        "generate-barrels": "node generate-barrels.js",
        "lint": "eslint . --ext .ts,.tsx",
        "pretest": "npm run lint",
        "test": "jest",
        "build-esm": "npm run generate-barrels && tsc --project tsconfig.prod.json && shx cp src/simulation/parallel/internal/resolveDefaultWorkerEntryUrl.mjs dist/esm/simulation/parallel/internal/resolveDefaultWorkerEntryUrl.mjs",
        "build-cjs": "npm run generate-barrels && tsc --project tsconfig.prod.json --module CommonJS --outDir dist/cjs && node write-cjs-package-json.js && shx cp src/simulation/parallel/internal/resolveDefaultWorkerEntryUrl.mjs dist/cjs/simulation/parallel/internal/resolveDefaultWorkerEntryUrl.mjs",
        "build-client": "tsc --project tsconfig.client.json && shx cp cli/client/index.html cli/client/style.css dist/cli/client/",
        "typecheck-studio-client": "tsc --project cli/studio-client/tsconfig.json --noEmit",
        "build-studio-client": "npm run typecheck-studio-client && vite build --config cli/studio-client/vite.config.ts",
        "dev-studio-client": "vite --config cli/studio-client/vite.config.ts",
        "build-cli": "tsc --project tsconfig.cli.json && npm run build-client && npm run build-studio-client && shx chmod +x dist/cli/pokie.js",
        "prebuild": "npm run lint",
        "build": "npm run generate-barrels && shx rm -rf ./dist && npm run build-esm && npm run build-cjs && npm run build-cli",
        "prepack": "npm run build"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/sta-ger/pokie.git"
    },
    "keywords": [
        "TypeScript",
        "JavaScript",
        "Casino",
        "Slot"
    ],
    "author": {
        "name": "sta-ger",
        "email": "pascaldelger@gmail.com",
        "url": "https://github.com/sta-ger"
    },
    "homepage": "https://github.com/sta-ger/pokie",
    "license": "ISC",
    "devDependencies": {
        "@mantine/core": "^9.4.1",
        "@mantine/form": "^9.4.1",
        "@mantine/hooks": "^9.4.1",
        "@mantine/modals": "^9.4.1",
        "@mantine/notifications": "^9.4.1",
        "@tabler/icons-react": "^3.44.0",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/jest": "^29.5.2",
        "@types/node": "^26.1.1",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@typescript-eslint/eslint-plugin": "^5.59.11",
        "@typescript-eslint/parser": "^5.59.11",
        "@vitejs/plugin-react": "^5.2.0",
        "eslint": "^8.42.0",
        "eslint-config-prettier": "^8.8.0",
        "eslint-plugin-eslint-comments": "^3.2.0",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.1.1",
        "fs-extra": "^11.1.1",
        "jest": "^29.5.0",
        "jest-environment-jsdom": "^29.7.0",
        "postcss": "^8.5.19",
        "postcss-preset-mantine": "^1.18.0",
        "postcss-simple-vars": "^7.0.1",
        "prettier": "^2.8.8",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "react-router-dom": "^7.18.1",
        "shx": "^0.3.4",
        "ts-jest": "^29.1.0",
        "typescript": "^5.0.4",
        "undici": "^8.7.0",
        "vite": "^8.1.5"
    },
    "files": [
        "dist/",
        "src/",
        "package.json"
    ],
    "dependencies": {
        "exceljs": "^4.4.0"
    }
}
